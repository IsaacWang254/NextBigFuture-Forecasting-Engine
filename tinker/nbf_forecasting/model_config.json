{
  "recipe": "nbf_forecasting",
  "baseModel": "meta-llama/Llama-3.2-1B",
  "adapter": {
    "type": "lora",
    "rank": 32
  },
  "trainingData": {
    "sftMessages": "data/articles/fermi-sft.jsonl",
    "fermiExamples": "data/articles/fermi-examples.jsonl",
    "articleRequests": "data/articles/fermi-transform-requests.jsonl"
  },
  "evaluation": {
    "heldoutForecasts": "data/forecasting/heldout.jsonl",
    "metrics": ["brier", "log_loss", "target_probability", "top1_accuracy"]
  },
  "output": {
    "checkpointName": "nbf-fermi-forecasting-1b",
    "notes": "1B-class Tinker SFT start, followed by probability-forecast RL using the scoring environment."
  }
}
